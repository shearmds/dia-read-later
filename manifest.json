{
  "manifest_version": 3,
  "name": "Read This Later for Dia",
  "version": "1.5",
  "description": "Save pages to read later, right from your toolbar.",
  "permissions": ["activeTab", "storage", "tabs", "alarms"],
  "host_permissions": ["https://readlater-sync.shearm.workers.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Save to Read This Later"
  },
  "commands": {
    "save-page": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Save current page to Read This Later"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
